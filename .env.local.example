# Database — get from neon.tech after creating a project
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Admin password — choose any password for the /admin panel
ADMIN_PASSWORD="your-admin-password-here"

# Session secret — must be at least 32 characters, random string
# Generate one with: openssl rand -hex 32
SESSION_SECRET="change-this-to-a-random-32-character-string-minimum"
