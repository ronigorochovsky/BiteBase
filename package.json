{
  "name": "bitebase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/start-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs studio",
    "db:sync": "node --env-file=.env.local scripts/sync-restaurants.mjs && node --env-file=.env.local scripts/sync-recipes.mjs",
    "db:sync:restaurants": "node --env-file=.env.local scripts/sync-restaurants.mjs",
    "db:sync:recipes": "node --env-file=.env.local scripts/sync-recipes.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@neondatabase/serverless": "^0.9.5",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.33.0",
    "iron-session": "^8.0.4",
    "leaflet": "^1.9.4",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1",
    "tailwind-merge": "^2.5.0",
    "whatsapp-chat-parser": "^4.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.24.0",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "playwright": "^1.59.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5"
  }
}
